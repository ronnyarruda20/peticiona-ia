<?xml version="1.0" encoding="UTF-8"?>
<!--
  Settings do Maven para ESTE projeto.

  Por que existe: a instalação global do Maven nesta máquina aponta para o Nexus
  corporativo (binrepo.poupex.com.br), que só resolve dentro da rede da empresa.
  Este projeto é pessoal e usa o Maven Central direto.

  Uso:  mvn -s settings.xml <goal>
  O build do Docker/Railway usa este arquivo automaticamente.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">

  <profiles>
    <profile>
      <id>central-direto</id>
      <repositories>
        <repository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>central-direto</activeProfile>
  </activeProfiles>
</settings>
